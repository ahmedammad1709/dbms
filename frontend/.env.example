# Frontend (Vite) environment variables (Vercel)
# Copy to .env for local dev.
# On Vercel, add these under: Project -> Settings -> Environment Variables.
# Note: Vite only exposes vars prefixed with VITE_.

# Required: Base URL of your backend API.
# Local dev example: http://localhost:5000
# Production example (Render): https://<your-render-service>.onrender.com
VITE_API_URL=

# Required for authentication: Neon Auth (used by `@neondatabase/neon-js/auth`).
# Without this, the UI can load, but login/signup will fail.

# Neon Auth URL (preferred name)
VITE_NEON_AUTH_URL=
# Back-compat alias used by the code (either one works)
VITE_NEON_URL=

# Optional: Neon Data API (used for persisting roles in a `user_roles` table).
# If not set, role storage may fall back to localStorage.

# Neon Data API URL (preferred name)
VITE_NEON_DATA_API_URL=
# Back-compat alias used by the code (either one works)
VITE_NEON_DATA_URL=

# Not used by the current code (kept for compatibility/documentation)
VITE_NEON_ANON_KEY=
