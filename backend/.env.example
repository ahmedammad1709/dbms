# Backend environment variables (Render)
# Copy to .env for local dev.
# On Render, add these under: Service -> Environment.

# Required: Postgres connection string used by `pg`.
# Example format:
# postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require
DATABASE_URL=

# Optional: Port for local development.
# Render injects PORT automatically.
PORT=5000

# Optional: Controls some controller behavior (some endpoints return `null` in production).
# Typical values: development | production
NODE_ENV=development
